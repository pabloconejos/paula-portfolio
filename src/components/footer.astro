<style>
  @font-face {
    font-family: "BricolageGrotesque";
    src: url("/fonts/bricolage_grotesques/BricolageGrotesque96pt-Bold.ttf")
      format("truetype");
    font-weight: 700;
    font-style: normal;
    font-display: swap;
  }

  :root {
    --footer-bg: red;
    --footer-color: #fff;
    --footer-pad: 1rem;
  }

  footer {
    margin-top: 30px;
    background: var(--footer-bg);
    color: var(--footer-color);
    padding: var(--footer-pad);
    font:
      1rem/1.4 "BricolageGrotesque",
      system-ui,
      -apple-system,
      Segoe UI,
      Roboto,
      Arial,
      sans-serif;
    overflow: hidden;
    display: flex;
    justify-content: space-between;
    align-items: end;
  }

  .titulo-footer {
    position: relative;
    display: inline-flex;
    align-items: baseline;
    gap: 0.25rem;
    width: fit-content;
  }

  /* Texto principal */
  .titulo-footer .name {
    margin: 0;
    padding: 0;
    font-weight: 700;
    font-size: 6rem;
    letter-spacing: -0.06em;
    line-height: 0.7;
    color: inherit;
    white-space: nowrap;
    margin-top: 4rem;
  }

  .titulo-footer .marca-registrada {
    margin: 0;
    position: absolute;
    top: 38px;
    right: -20px;
    font-size: clamp(1.5rem, 5vmin, 6rem);
    align-self: flex-center;
  }

  footer p {
    margin: 0;
    padding: 0;
    font-size: 2rem;
    line-height: 1;
    color: inherit;
    white-space: nowrap;
    margin-top: 4rem;
  }

  footer a {
    color: inherit;
    text-decoration: none;
  }

  footer a:hover {
    text-decoration: underline;
  }
</style>

<footer>
  <div class="titulo-footer">
    <p class="name">Paula</p>
    <p class="marca-registrada">®</p>
  </div>
  <p><a href="mailto:paulalberola.work@gmail.com">paulalberola.work@gmail.com</a></p>
</footer>
