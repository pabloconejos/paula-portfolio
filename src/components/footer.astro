<style>
  @font-face {
    font-family: "BricolageGrotesque";
    src: url("/fonts/bricolage_grotesques/BricolageGrotesque96pt-Bold.ttf")
      format("truetype");
    font-weight: 700;
    font-style: normal;
    font-display: swap;
  }

  :root {
    --footer-bg: red;
    --footer-color: #fff;
    --footer-pad: 1rem;
  }

  footer {
    background: var(--footer-bg);
    color: var(--footer-color);
    padding: var(--footer-pad);
    font:
      1rem/1.4 "BricolageGrotesque",
      system-ui,
      -apple-system,
      Segoe UI,
      Roboto,
      Arial,
      sans-serif;
    overflow: hidden;
    display: flex;
    justify-content: space-between;
    align-items: end;
  }

  .titulo-footer {
    position: relative;
    display: inline-flex;
    align-items: baseline;
    gap: 0.25rem;
    width: fit-content;
  }

  /* Texto principal */
  .titulo-footer .name {
    margin: 0;
    padding: 0;
    font-weight: 700;
    font-size: 6rem;
    letter-spacing: -0.06em;
    line-height: 0.7;
    color: inherit;
    white-space: nowrap;
    margin-top: 4rem;
  }

  .titulo-footer .marca-registrada {
    margin: 0;
    position: absolute;
    top: 38px;
    right: -20px;
    font-size: clamp(1.5rem, 5vmin, 6rem);
    align-self: flex-center;
  }

  /* Tamaño de fuente base */
  footer p {
    font-size: 2rem;
    margin: 0;
  }

  /* Tablets (pantallas medianas) */
  @media (max-width: 1024px) {
    footer p {
      font-size: 1.6rem;
    }

    .titulo-footer .name {
      font-size: 5rem;
    }
  }

  /* Móviles grandes (ancho ≤ 768px) */
  @media (max-width: 768px) {
    footer {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .titulo-footer {
      flex-direction: column;
      align-items: center;
    }

    .titulo-footer .name {
      font-size: 4rem;
      margin-top: 2rem;
    }

    .titulo-footer .marca-registrada {
      top: 20px;
      right: -10px;
      font-size: 2rem;
    }

    footer p {
      font-size: 1.4rem;
      margin-top: 1rem;
    }
  }

  /* Móviles pequeños (ancho ≤ 480px) */
  @media (max-width: 480px) {
    .titulo-footer .name {
      font-size: 3rem;
      margin-top: 1rem;
    }

    .titulo-footer .marca-registrada {
      top: 12px;
      right: -8px;
      font-size: 1.4rem;
    }

    footer p {
      font-size: 1.1rem;
      margin-top: 0.5rem;
      word-break: break-all; /* Evita que el correo desborde el contenedor */
    }

    footer a {
      color: white;
      text-decoration: none;
    }
  }

  footer a {
    color: white;
    text-decoration: none;
  }

  footer a:hover {
    text-decoration: underline;
  }

  .correo {
       position: relative;
    display: inline-flex;
    align-items: baseline;
    gap: 0.25rem;
    width: fit-content;
  }
</style>

<footer>
  <div class="titulo-footer">
    <p class="name">Paula</p>
    <p class="marca-registrada">®</p>
  </div>
  <p class="correo">
    <a href="mailto:paulalberola.work@gmail.com">paulalberola.work@gmail.com</a>
  </p>
</footer>
