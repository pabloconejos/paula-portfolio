<style>
  @font-face {
    font-family: "BricolageGrotesque";
    src: url("/fonts/bricolage_grotesques/BricolageGrotesque96pt-Bold.ttf") format("truetype");
    font-weight: 700;
    font-style: normal;
    font-display: swap;
  }

  :root {
    --footer-bg: #e10600;
    --footer-color: #fff;
    --footer-pad: 1rem;
  }

  footer {
    margin-top: 4rem;
    background: var(--footer-bg);
    color: var(--footer-color);
    padding: var(--footer-pad);
    font: 1rem/1.4 "BricolageGrotesque", system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
    overflow: hidden;

    /* opcional: centrar el bloque del título */
    display: flex;
    justify-content: start;
  }

  .titulo-footer {
    display: inline-flex;           /* se ajusta al contenido */
    align-items: baseline;
    gap: .25rem;
    width: fit-content;             /* bloque reducido al contenido */
    opacity: 0;
    margin-top: 100px;
    transform: translateX(340px);
    transition: opacity 600ms ease, transform 600ms ease;
  }

  .titulo-footer.visible-footer {
    opacity: 1;
    transform: translateX(0);
  }

  /* Texto principal */
  .titulo-footer .name {
    margin: 0;                      /* elimina el margen enorme */
    padding: 0;
    font-weight: 700;
    font-size: clamp(3rem, 25vmin, 24rem);
    letter-spacing: -0.06em;
    line-height: 0.7;
    color: inherit;
    white-space: nowrap;
  }

  .titulo-footer .marca-registrada {
    margin: 0;                      /* elimina margen por defecto */
    font-size: clamp(1.5rem, 5vmin, 6rem);
    align-self: flex-start;
  }

  /* Accesibilidad: respeta usuarios con reducción de movimiento */
  @media (prefers-reduced-motion: reduce) {
    .titulo-footer {
      transition: none;
      transform: none;
      opacity: 1;
    }
  }
</style>

<footer>
  <div class="titulo-footer" id="footerTitulo">
    <p class="name">Paula</p>
    <p class="marca-registrada">®</p>
  </div>
</footer>

<script>
  (function () {
    var el = document.getElementById("footerTitulo");
    if (!el) return;

    // Si no hay soporte de IntersectionObserver, muestra sin animación
    if (!("IntersectionObserver" in window)) {
      el.classList.add("visible-footer");
      return;
    }

    var io = new IntersectionObserver(function (entries) {
      for (var i = 0; i < entries.length; i++) {
        if (entries[i].isIntersecting) {
          el!.classList.add("visible-footer"); // corregido, sin el "!"
          io.unobserve(el!);
          break;
        }
      }
    }, { threshold: 0.3 });

    io.observe(el);
  })();
</script>
