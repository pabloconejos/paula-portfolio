<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    grid-template-rows: repeat(9, 0.9fr); /* un poco más altas las filas */
    gap: 12px;
    max-width: 950px; /* más ancho que antes */
    margin: 0 auto;
  }

  .item {
    overflow: hidden;
    border-radius: 8px;
  }

  img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 8px;
    transition: transform 0.3s ease;
  }

  img:hover {
    transform: scale(1.03);
  }

  .item-0 {
    grid-column: 1 / span 3;
    grid-row: 1 / span 3;
  }

  .item-1 {
    grid-column: 1 / span 3;
    grid-row: 4 / span 3;
  }

  .item-2 {
    grid-column: 4 / span 3;
    grid-row: 1 / span 6;
  }

  .item-3 {
    grid-column: 3 / span 4;
    grid-row: 7 / span 3;
  }

  .item-4 {
    grid-column: 1 / span 2;
    grid-row: 7 / span 3;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .grid {
      max-width: 750px; /* ajusta para pantallas medianas */
    }
  }

  @media (max-width: 768px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: auto;
      gap: 12px;
      max-width: 100%;
    }
    .item {
      grid-column: auto / span 1 !important;
      grid-row: auto / span 1 !important;
    }
  }
</style>

<div class="grid">
  <div class="item item-0">
    <img src="/fotos/dupla/d.jpg" alt="">
  </div>
  <div class="item item-1">
    <img src="/fotos/dupla/c.jpg" alt="">
  </div>
  <div class="item item-2">
    <img src="/fotos/dupla/a.jpg" alt="">
  </div>
  <div class="item item-3">
    <img src="/fotos/dupla/b.jpg" alt="">
  </div>
  <div class="item item-4">
    <img src="/fotos/dupla/e.jpg" alt="">
  </div>
</div>
