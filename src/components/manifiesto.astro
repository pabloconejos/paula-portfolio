<style>

	.part-two {
		position: relative;
		width: 100%;
		height: 100vh;
		/* padding: 40px; quitamos padding para que el overlay cubra todo */
		display: flex;
		align-items: center;
		justify-content: center;
		/* padding: 20px; quitamos padding */
	}
   
	.img-overlay {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: 2;
		/* Importante: Necesario para que el mousemove funcione en toda el area */
		pointer-events: auto; /* Asegura que el div capture eventos del ratón */
	}
   
	.img-overlay img {
		position: absolute;
		/* Añadimos transición para suavizar el movimiento */
		transition: transform 0.2s ease-out;
		/* Importante: Evita que las imágenes capturen el evento del ratón */
		pointer-events: none;
	}
   
	/* Tus estilos originales para las imágenes */
	.img-mac { top: 17%; left: 7%;height: 330px; }
	.img-chicles { bottom: 25%; left: 16%; height: 160px;}
	.img-gafas { bottom: 15%; left: 40%; height: 180px;}
	.img-cacao { top: 22%; left: 32%; height: 120px;}
	.img-headphones { top: 25%; right: 17%; height: 250px; z-index: 1;}
	.img-lapices { top: 30%; left: 45%; height: 300px }
	.img-matcha { bottom: 30%; left: 55%; height: 150px;}
	.img-papel { bottom: 33%; left: 40%; height: 120px;}
	.img-posits { top: 16%; right: 35%; height: 300px; }
	.img-papeles { top: 25%; right: 15%; height: 200px;}
	.img-libreta { bottom: 25%; left: 30%; height: 200px;}
	.img-walpaperIphone { bottom: 24%; right: 24%; height: 200px; border-radius: 10px; border: solid 2px black;} /* Corregido '2x' a '2px' */
   
	.txt {
		z-index: 1;
		position: relative;
		color: white;
		font-size: 80px;
		line-height: 0.8;
		text-align: center;
		max-width: 900px;
        font-family: Arial, Helvetica, sans-serif;
		text-align: start; /* Cuidado, esto anula el text-align: center anterior */
	}
   
	.txt span {
		font-weight: bold;
	}

	@media (max-width: 600px) {
		.img-overlay {
			display: none;
		}

		.txt {
			font-size: 50px;
			margin: 20px;
		}
	}

</style>
   
<div class="part-two">
	<div class="img-overlay">
	   <img src="fotos/manifiesto/mac.png" alt="" class="img-mac" data-transform="rotate(-10deg)">
	   <img src="fotos/manifiesto/chiclesOrbit.png" alt="" class="img-chicles" data-transform="rotate(-40deg)">
	   <img src="fotos/manifiesto/gafas.png" alt="" class="img-gafas" data-transform="">
	   <img src="fotos/manifiesto/cacao.png" alt="" class="img-cacao" data-transform="">
	   <img src="fotos/manifiesto/headphones.png" alt="" class="img-headphones" data-transform="rotate(40deg)">
	   <img src="fotos/manifiesto/lapices.png" alt="" class="img-lapices" data-transform="rotate(-50deg)">
	   <img src="fotos/manifiesto/matcha.png" alt="" class="img-matcha" data-transform="rotate(90deg)">
	   <img src="fotos/manifiesto/papelBlanco.png" alt="" class="img-papel" data-transform="rotate(5deg)">
	   <img src="fotos/manifiesto/posits.png" alt="" class="img-posits" data-transform="rotate(-70deg)">
	   <img src="fotos/manifiesto/papeles.png" alt="" class="img-papeles" data-transform="">
	   <img src="fotos/manifiesto/libreta.png" alt="" class="img-libreta" data-transform="rotate(-20deg)">
	   <img src="fotos/manifiesto/walpaperIphone.jpg" alt="" class="img-walpaperIphone" data-transform="rotate(20deg)">
	</div>
   
	<p class="txt">
	   Siempre he pensado que las ideas buenas necesitan <span>paz</span> para coger forma y <span>caos</span> para cobrar vida
	</p>
</div>
   
 <script>
	const overlay = document.querySelector('.img-overlay');
	const images = overlay!.querySelectorAll('img');

	// --- Parámetros del Efecto (AJUSTADOS PARA MAYOR MOVIMIENTO) ---
	const repulsionRadius = 300; // Aumentado: El ratón afecta desde más lejos (antes 150)
	const maxPushDistance = 800; // Aumentado MUCHO: Las imágenes se empujan mucho más lejos (antes 40)
	const stiffness = 0.1;      // Mantenido o ligeramente aumentado si se quiere más rápido (ej: 0.12)
	// --------------------------------------------------------------

	// Almacenar la posición objetivo de cada imagen
	const targets = Array.from(images).map(img => ({
		element: img,
		targetX: 0,
		targetY: 0,
		currentX: 0,
		currentY: 0,
		originalTransform: img.dataset.transform || '' // Leer la transformación original
	}));

	let mouseX = -1000; // Inicializar fuera de la pantalla
	let mouseY = -1000;

	overlay!.addEventListener('mousemove', (event: any) => {
		// Usamos clientX/clientY que son relativos a la ventana
		mouseX = event.clientX;
		mouseY = event.clientY;
	});

	overlay!.addEventListener('mouseleave', () => {
		// Mover el ratón "virtualmente" fuera cuando sale del contenedor
		mouseX = -1000;
		mouseY = -1000;
	});

	function updateImagePositions() {
		targets.forEach(item => {
			const img = item.element;
			const rect = img.getBoundingClientRect(); // Posición actual en pantalla

			// Centro de la imagen (relativo a la ventana)
			const imgCenterX = rect.left + rect.width / 2;
			const imgCenterY = rect.top + rect.height / 2;

			// Vector desde el ratón a la imagen
			const deltaX = imgCenterX - mouseX;
			const deltaY = imgCenterY - mouseY;

			// Distancia entre el ratón y el centro de la imagen
			const distance = Math.sqrt(deltaX * deltaX + deltaY * deltaY);

			let targetPushX = 0;
			let targetPushY = 0;

			// Evitar división por cero si distance es 0
			if (distance < repulsionRadius && distance > 0) {
				// Calcular cuánto empujar basado en la cercanía
				// La fuerza es mayor cuanto más cerca está el ratón
				const proximityFactor = 1 - (distance / repulsionRadius); // 0 (lejos) a 1 (cerca)
				const pushForce = proximityFactor * maxPushDistance;

				// Calcular la dirección del empuje (vector unitario normalizado)
				const pushDirectionX = deltaX / distance;
				const pushDirectionY = deltaY / distance;

				// Calcular el desplazamiento objetivo
				targetPushX = pushDirectionX * pushForce;
				targetPushY = pushDirectionY * pushForce;
			} else if (distance === 0) {
				// Si el ratón está EXACTAMENTE en el centro, empujar en una dirección aleatoria o fija
				 targetPushX = maxPushDistance;
				 targetPushY = 0; // O alguna lógica para evitar quedarse quieto
			}


			// Actualizar la posición objetivo
			item.targetX = targetPushX;
			item.targetY = targetPushY;

			// Interpolar suavemente hacia la posición objetivo
			item.currentX += (item.targetX - item.currentX) * stiffness;
			item.currentY += (item.targetY - item.currentY) * stiffness;

			// Aplicar la transformación combinada (empuje + rotación original)
			// Redondeamos para evitar pixelación borrosa en algunos navegadores
			const finalX = Math.round(item.currentX);
			const finalY = Math.round(item.currentY);
			// Asegúrate que item.originalTransform tiene la rotación correcta leída del data-attribute
			img.style.transform = `translate(${finalX}px, ${finalY}px) ${item.originalTransform}`;

		});

		// Solicitar el siguiente frame de animación
		requestAnimationFrame(updateImagePositions);
	}

	// Iniciar el bucle de animación
	updateImagePositions();

</script>
