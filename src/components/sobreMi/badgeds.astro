---
const badgeds = [
  {
    name: "¡Dime Hola!",
    url: "mailto:paulalberola.work@gmail.com?subject=Hola&body=¡Hola!%20Quiero%20ponerme%20en%20contacto.",
    style: "badged",
    type: "mail",
  },
  {
    name: "Instagram",
    url: "https://www.instagram.com/paulalberola/",
    style: "badged",
    type: "ig",
  },
  // {
  //   name: "Conoce a LADOBLEP",
  //   url: "/midupla",
  //   style: "badged",
  // },
];
---

<style>
  .badgeds {
    display: flex;
    justify-content: start;
    align-items: center;
    gap: 32px;
    flex-wrap: wrap; /* permite que los botones bajen de línea */
    font-family: system-ui, sans-serif;
  }

  .badged {
    position: relative;
    display: inline-block;
    padding: 12px 28px;
    border: 1.5px solid red;
    border-radius: 999px;
    color: red;
    text-decoration: none;
    overflow: hidden;
    transition:
      color 0.25s ease,
      transform 0.25s ease;
  }

  .badged::before {
    content: "";
    position: absolute;
    inset: 0;
    background: red;
    transform: translateX(-100%);
    transition: transform 0.35s ease;
    z-index: 0;
  }

  .badged > span {
    position: relative;
    z-index: 1;
    font-weight: 600;
    white-space: nowrap; /* evita saltos de línea dentro del texto */
  }

  .badged:hover {
    color: #fff;
  }

  .badged:hover::before {
    transform: translateX(0);
  }

  /* Responsive */
  @media (max-width: 900px) {
    .badgeds {
      gap: 24px;
      justify-content: center;
    }
    .badged {
      padding: 10px 22px;
      font-size: 0.95rem;
    }
  }

  @media (max-width: 600px) {
    .badgeds {
      gap: 16px;
      flex-direction: column; /* los botones se apilan */
      align-items: center;
    }
    .badged {
      width: 80%;
      max-width: 250px;
      text-align: center;
      padding: 10px 18px;
      font-size: 0.9rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .badged::before,
    .badged,
    .link-text {
      transition: none;
    }
  }
</style>

<div class="badgeds">
  {
    badgeds.map((pill) => {
      return (
        <a
          class={pill.style}
          href={pill.url}
          target={pill.type === "ig" ? "_blank" : undefined}
        >
          <span>{pill.name}</span>
        </a>
      );
    })
  }
</div>
