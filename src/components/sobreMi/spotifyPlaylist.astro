---
export interface PlaylistItem {
  id?: string | number;
  image: string;
  title: string;
  subtitle?: string;
  url?: string;
}

interface Props {
  title?: string;
  items?: PlaylistItem[];
}

const demoItems: PlaylistItem[] = [
  { image: "/fotos/playlist/im_just_girl.webp", title: "I´m just a girl", url: 'https://open.spotify.com/playlist/2if96pgxsWJgykCuHJWTj6?si=-RS_PrKoSbC_o7runFD1pw' },
  { image: "/fotos/playlist/hiperactividad.webp", title: "Hiperactividad at 3am", url: 'https://open.spotify.com/playlist/7pecJTdziOufoNzRyYhWEc?si=1G66PvqxQiOzcBF_1rf3fQ' },
  { image: "/fotos/playlist/mananas_bonitas.webp", title: "Mañanas bonitas", url: 'https://open.spotify.com/playlist/3cqPoSdvLN2oli9kTtuCoF?si=ZdfKkLwnQ42iSuLvJPZqCA' },
  { image: "/fotos/playlist/afterwork.jpeg", title: "After work", url: 'https://open.spotify.com/playlist/3fRCs0ixf1Fvt6pI1fjY5Z?si=HPqwma7cTmmVI8y0fJOoEQ' },
];

const { title = "Mis playlists favoritas :)", items = demoItems } = Astro.props as Props;
---

<style>
  /* Evita que los bordes/ padding sumen ancho y provoquen overflow */
  :where(.playlist-section, .playlist-section *) { box-sizing: border-box; }

  :root {
    --gap: clamp(.75rem, 1.8vw, 1rem);
    --brand: red;
    --surface: #fff;
    --radius: 12px;
    --border: red;
  }



  .playlist-section {
    width: min(1100px, 100%);
    margin-inline: auto;
    margin-top: 100px;
    container-type: inline-size; /* habilita @container (opcional) */
  }

  .playlist-title {
    margin: 0 0 clamp(1rem, 3vw, 2rem);
    color: var(--brand);
    font-weight: 900;
    font-size: clamp(1.8rem, 6vw, 3rem);
    line-height: 1;
    letter-spacing: -.02em;
    font-family: system-ui, sans-serif;
  }

  /* GRID RESPONSIVE sin desbordes */
  .playlist-grid {
    display: grid;
    gap: var(--gap);
    /* 220px mínimo por tarjeta; se rellena con 1fr sin provocar anchos fijos */
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    align-items: stretch;
  }

  /* La tarjeta NUNCA tiene ancho fijo */
  .playlist-card {
    width: 100%;                /* clave para evitar overflow */
    background: var(--surface);
    border: 2px solid var(--border);
    border-radius: var(--radius);
    overflow: clip;
    display: flex;
    flex-direction: column;
    transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
  }
  .playlist-card:hover { transform: translateY(-2px); box-shadow: 0 8px 18px rgba(0,0,0,.15); cursor: pointer; }

  .playlist-img {
    display: block;
    inline-size: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-bottom: 2px solid var(--border);
  }

  .playlist-info {
    padding: 1rem;
    text-align: start;
  }

  .playlist-info h3 {
    margin: 0 0 .25rem;
    color: var(--brand);
    font: 700 clamp(1.05rem, 2.3vw, 1.35rem)/1.2 system-ui, sans-serif;
    /* evita cortes feos si el mes es largo y el ancho es pequeño */
    overflow-wrap: anywhere;
  }

  .playlist-info p {
    margin: 0;
    color: var(--text);
    font: 500 clamp(.95rem, 2vw, 1.1rem)/1.35 system-ui, sans-serif;
  }

  .playlist-info .subtitle {
    margin-top: .25rem;
    color: var(--text-subtle);
    font-size: clamp(.85rem, 1.8vw, .95rem);
  }

  /* Ajustes para pantallas muy pequeñas */
  @media (max-width: 380px) {
    .playlist-grid { grid-template-columns: 1fr; }
    .playlist-title { font-size: clamp(1.6rem, 8vw, 2.2rem); }
  }

  /* Si usas @container, mejora columnas en contenedor ancho */
  @container (min-width: 900px) {
    .playlist-grid { grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); }
  }

  a {
    text-decoration: none;
    color: inherit;
  }
  
</style>

<section class="playlist-section" aria-labelledby="playlist-heading">
  <h1 id="playlist-heading" class="playlist-title">{title}</h1>

  {items?.length ? (
    <div class="playlist-grid" role="list">
      {items.map((p) => (
        <a href={p.url} target="_blank" rel="noopener noreferrer">
        <article class="playlist-card" role="listitem" aria-label={`${p.title}`}>
          <img
            src={p.image}
            alt={p.title}
            class="playlist-img"
            loading="lazy"
            decoding="async"
            sizes="(max-width: 480px) 90vw, (max-width: 900px) 45vw, 240px"
          />
          <div class="playlist-info">
            <h3>{p.title}</h3>
            {p.subtitle && <p class="subtitle">{p.subtitle}</p>}
          </div>
        </article>
        </a>
      ))}
    </div>
  ) : (
    <p role="status">No hay playlists para mostrar.</p>
  )}
</section>
