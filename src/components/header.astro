<style>
  header {
    display: flex;
    justify-content: end;
    align-items: center;
    width: 100%;
    position: fixed;
    top: 0;
    z-index: 1000;
    padding: 10px 30px 10px 10px;
    box-sizing: border-box;
  }

  nav {
    display: flex;
    gap: 30px;
  }

  nav p {
    color: red;
    font-size: 1.9vmin;
    font-family: Arial, Helvetica, sans-serif;
    transform: translateY(20px);
    animation: fadeInUp 1s ease forwards;
    cursor: pointer;
    letter-spacing: -0.9px;
  }

  a {
    text-decoration: none;
    color: red;
  }

  a:hover {
    text-decoration: underline;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<header class="header">
  <nav>
    <p><a href="/sobremi">SOBRE MÍ</a></p>
    <p><a href="">CONTACTO</a></p>
  </nav>
</header>


