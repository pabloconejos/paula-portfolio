---
const currentPath = Astro.url.pathname;

const navItems = [
  { name: 'Home', path: '/' },
  { name: 'About', path: '/sobremi' },
];

const activeIndex = navItems.findIndex(item => {
  if (item.path === '/') return currentPath === '/';
  return currentPath !== '/' && currentPath.startsWith(item.path);
});
---
<nav class="nav" aria-label="Main">
  <div class="track">
    <ul class="list">
      {navItems.map((item, index) => (
        <li class="item">
          <a
            href={item.path}
            class:list={['link', { active: index === activeIndex }]}
          >
            {item.name}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    bottom: 50px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1000;
  }
  .track {
    position: relative;
    background: #ececec;
    border-radius: 999px;
    padding: 6px;
    box-shadow: 0 6px 18px rgba(0,0,0,.08) inset, 0 4px 16px rgba(0,0,0,.06);
  }
  .list {
    display: flex;
    gap: 6px;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .link {
    position: relative;
    display: block;
    padding: 14px 28px;
    text-decoration: none;
    color: #111;
    font-weight: 600;
    font-size: 18px;
    font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
    border-radius: 999px;
    white-space: nowrap;
    transition: color .2s ease;
  }
  .link::before {
    content: "";
    position: absolute;
    inset: 0;                 /* ocupa todo el botón */
    border-radius: inherit;
    background: #000;         /* cámbialo a #d33 si la quieres roja */
    z-index: -1;              /* queda detrás del texto */
    transform: scale(0.96);   /* ligero encogido */
    opacity: 0;               /* oculta por defecto */
    transition: opacity .28s cubic-bezier(.4,0,.2,1),
                transform .28s cubic-bezier(.4,0,.2,1);
  }
  .link.active { color: red; }
  .link.active::before {
    opacity: 1;
    transform: scale(1);      /* “aparece” la mancha */
  }

  /* (Opcional) también muévela en hover dentro de la misma página */
  .link:not(.active):hover::before { opacity: .12; }

  @media (prefers-reduced-motion: reduce) {
    .link::before { transition: none; }
  }
</style>

