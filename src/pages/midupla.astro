<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    @font-face {
      font-family: "BricolageGrotesque";
      src: url("/fonts/bricolage_grotesques/BricolageGrotesque96pt-Bold.ttf")
        format("truetype");
      font-weight: normal;
      font-style: normal;
    }

    body {
      margin: 0;
      padding: 0;
      min-height: 200vh;
      background: #f5f5f5;
    }

    .asi-soy-section {
      display: flex;
      justify-content: space-between;
      align-items: end;
      margin-top: 300px;
      margin-bottom: 130px;
      padding: 0 50px;
    }

    .img-section {
      width: 500px;
      animation: reveal linear both;
      animation-timeline: view();
      animation-range: entry 20% cover 30%;
    }

    .img-section img {
      width: 100%;
    }

    .texto-section {
      animation: reveal linear both;
      animation-timeline: view();
      animation-range: entry 20% cover 30%;
    }

    .texto-section p {
      font-family: Arial, Helvetica, sans-serif;
      color: red;
      font-size: 1.4rem;
      max-width: 500px;
      text-align: justify;
      margin: 0;
    }

    .texto-section h1 {
      font-family: "BricolageGrotesque", sans-serif;
      font-size: 5rem;
      letter-spacing: -1px;
      line-height: 0;
      color: red;
    }

    /* Ocultar caracteres inicialmente */
    .texto-section p span {
      opacity: 0;
    }

    .texto-section p span.visible {
      opacity: 1;
      transition: opacity 0.1s ease;
    }

    @keyframes reveal {
      from {
        opacity: 0;
        translate: 0 100px;
      }
      to {
        opacity: 1;
        translate: 0 0;
      }
    }
  </style>
</head>
<body>
  <div class="asi-soy-section">
    <div class="img-section">
      <img src="/fotos/sobremi/sobremi_metro_londres.webp" alt="">
    </div>
    
    <section class="texto-section">
      <p id="typing-text">
        <strong>No sé quedarme quieta;</strong> siempre estoy pensando en proyectos,
        ideas o formas distintas de exprimir mi creatividad. aunque estoy dando mis
        primeros pasos en el mundo de la publicidad, he trabajado en otros sectores
        que me han enseñado a observar, comunicar y escuchar a las personas desde cerca.
        De ahí nace mi forma de entender la comunicación:
        <strong>cercana, humana y revolucionaria.</strong>
      </p>
    </section>
  </div>

  <script>
    // Función para envolver cada carácter en un span
    function wrapCharacters() {
      const textElement = document.getElementById('typing-text')!;
      const originalHTML = textElement!.innerHTML;
      
      // Crear un contenedor temporal para procesar el HTML
      const temp = document.createElement('div');
      temp.innerHTML = originalHTML;
      
      // Función recursiva para procesar nodos
      function processNode(node: any) {
        if (node.nodeType === Node.TEXT_NODE) {
          const text = node.textContent;
          const fragment = document.createDocumentFragment();
          
          for (let char of text) {
            const span = document.createElement('span');
            span.textContent = char;
            span.className = 'char';
            fragment.appendChild(span);
          }
          
          return fragment;
        } else if (node.nodeType === Node.ELEMENT_NODE) {
          const newNode = node.cloneNode(false);
          for (let child of node.childNodes) {
            newNode.appendChild(processNode(child));
          }
          return newNode;
        }
        return node.cloneNode(true);
      }
      
      textElement.innerHTML = '';
      for (let child of temp.childNodes) {
        textElement.appendChild(processNode(child));
      }
    }

    // Función para manejar el efecto de escritura con scroll
    function setupScrollTyping() {
      const textElement = document.getElementById('typing-text')!;
      const chars = textElement!.querySelectorAll('.char');
      const section = document.querySelector('.asi-soy-section')!;
      
      function updateVisibleChars() {
        const rect = section!.getBoundingClientRect();
        const windowHeight = window.innerHeight;
        
        // Calcular el progreso del scroll (0 a 1)
        const start = windowHeight * 0.8; // Comienza cuando la sección está al 80% de la ventana
        const end = windowHeight * 0.2;   // Termina cuando está al 20% de la ventana
        
        let progress = 0;
        if (rect.top <= start && rect.top >= end) {
          progress = (start - rect.top) / (start - end);
        } else if (rect.top < end) {
          progress = 1;
        }
        
        // Mostrar caracteres basándose en el progreso
        const visibleCount = Math.floor(chars.length * progress);
        
        chars.forEach((char, index) => {
          if (index < visibleCount) {
            char.classList.add('visible');
          } else {
            char.classList.remove('visible');
          }
        });
      }
      
      // Usar requestAnimationFrame para mejor rendimiento
      let ticking = false;
      window.addEventListener('scroll', () => {
        if (!ticking) {
          window.requestAnimationFrame(() => {
            updateVisibleChars();
            ticking = false;
          });
          ticking = true;
        }
      });
      
      // Actualizar al cargar
      updateVisibleChars();
    }

    // Inicializar cuando el DOM esté listo
    wrapCharacters();
    setupScrollTyping();
  </script>
</body>
</html>